{
  "$schema": "https://glama.ai/mcp/schemas/server.json",
  "maintainers": ["Neuropolis-ai"],
  "name": "clipia-mcp",
  "description": "Hosted remote MCP server for AI image and video generation through one Streamable HTTP endpoint.",
  "type": "mcp_server",
  "status": "stable",
  "transport": ["streamable-http"],
  "tools": 8,
  "keywords": [
    "mcp",
    "remote-mcp",
    "streamable-http",
    "image-generation",
    "video-generation",
    "prompt-templates"
  ],
  "features": {
    "media_generation": {
      "enabled": true,
      "capabilities": [
        "generate images",
        "generate videos",
        "poll generation status",
        "browse model catalog",
        "search prompt templates",
        "check credit balance"
      ]
    }
  }
}
